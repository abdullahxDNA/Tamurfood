# ─── Local Development ────────────────────────────────────────────────────────

# Local Supabase PostgreSQL (from: supabase start)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Better Auth
# Must be at least 32 characters — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32-value-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# CORS (Vite dev server)
CORS_ORIGIN=http://localhost:5173

# Resend (password-reset emails) — optional. Get a key at resend.com.
# RESEND_FROM must be a VERIFIED sender (e.g. noreply@yourdomain.com) to email
# real users; the default test sender only reaches your own Resend account email.
RESEND_API_KEY=
RESEND_FROM=

# Supabase (server — image uploads via service role)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY from `supabase status -o env`>

# Error tracking (Sentry) — optional; leave blank locally to keep it off.
# SENTRY_DSN        → backend DSN (server errors)
# VITE_SENTRY_DSN   → frontend DSN (browser errors; baked in at build time)
SENTRY_DSN=
VITE_SENTRY_DSN=

# ─── Production (Railway) ─────────────────────────────────────────────────────
# Set these as environment variables in your Railway project.

# DATABASE_URL       → provided automatically by Railway PostgreSQL plugin
# PORT               → provided automatically by Railway (do not set manually)
# NODE_ENV           → production
# BETTER_AUTH_SECRET → openssl rand -hex 32
# BETTER_AUTH_URL    → https://your-app.up.railway.app
# CORS_ORIGIN        → https://your-app.up.railway.app  (same as BETTER_AUTH_URL)
# RESEND_API_KEY     → Resend API key (optional, for password-reset emails)
# RESEND_FROM        → verified sender, e.g. "Tamurfood <noreply@yourdomain.com>"
# SENTRY_DSN         → backend Sentry DSN (optional, for server error tracking)
#
# Build-time (set in Railway service Variables, used during Docker build):
# VITE_SENTRY_DSN        → frontend Sentry DSN (optional, for browser error tracking)
