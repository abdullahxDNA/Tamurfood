{
  "name": "tamurfood",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "drizzle-orm": "0.45.2"
  },
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --cwd apps/web build",
    "check-types": "bun run --filter '*' check-types",
    "lint": "bun run --filter '*' lint",
    "test": "bun test",
    "format": "prettier --write \"apps/**/*.{ts,tsx}\" \"packages/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx}\" \"packages/**/*.ts\" \"*.{json,md}\"",
    "db:generate": "bun run --cwd packages/db generate",
    "db:migrate": "bun run --cwd packages/db migrate",
    "db:studio": "bun run --cwd packages/db studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,json,md}": "prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.9.0",
    "better-auth": "^1.6.23",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30"
  }
}
